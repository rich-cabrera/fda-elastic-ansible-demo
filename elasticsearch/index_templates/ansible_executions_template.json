{
  "index_patterns": ["fda-demo-ansible-executions-*"],
  "priority": 200,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 1
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "id": {
          "type": "long"
        },
        "name": {
          "type": "keyword"
        },
        "url": {
          "type": "keyword"
        },
        "created_by": {
          "type": "keyword"
        },
        "started": {
          "type": "date"
        },
        "finished": {
          "type": "date"
        },
        "status": {
          "type": "keyword"
        },
        "traceback": {
          "type": "text"
        },
        "inventory": {
          "type": "keyword"
        },
        "project": {
          "type": "keyword"
        },
        "playbook": {
          "type": "keyword"
        },
        "credential": {
          "type": "keyword"
        },
        "limit": {
          "type": "keyword"
        },
        "extra_vars": {
          "type": "flattened"
        },
        "hosts": {
          "type": "object",
          "enabled": true
        }
      }
    }
  }
}
