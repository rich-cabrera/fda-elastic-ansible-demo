# =============================================================================
# FDA Demo - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Elastic / Kibana
ELASTICSEARCH_HOST=https://your-elasticsearch-host
KIBANA_HOST=https://your-kibana-host
ELASTIC_PASSWORD=your-elastic-password
ELASTIC_API_KEY=your-api-key

# Fleet
FLEET_ENROLLMENT_TOKEN=your-fleet-enrollment-token
FLEET_URL=https://your-fleet-server:8220

# FDA
FDA_FACILITY_ID=your-facility-id

# Ansible Automation Platform
AAP_API_KEY=your-aap-api-key

# EDA
EDA_WEBHOOK_SECRET=your-webhook-secret
