<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FDA 21 CFR Part 11 Compliance Audit Report</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            line-height: 1.6;
            background: #f5f5f5;
        }
        .container {
            max-width: 1100px;
            margin: 0 auto;
            background: #fff;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }
        .header {
            background: linear-gradient(135deg, #1a237e, #283593);
            color: #fff;
            padding: 30px 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .header-text h1 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 5px;
        }
        .header-text h2 {
            font-size: 16px;
            font-weight: 300;
            opacity: 0.9;
        }
        .fda-logo-placeholder {
            width: 80px;
            height: 80px;
            border: 2px solid rgba(255,255,255,0.5);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            text-align: center;
            opacity: 0.8;
        }
        .metadata {
            background: #e8eaf6;
            padding: 20px 40px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            border-bottom: 3px solid #1a237e;
        }
        .metadata-item {
            font-size: 14px;
        }
        .metadata-item strong {
            color: #1a237e;
        }
        .content {
            padding: 30px 40px;
        }
        .section {
            margin-bottom: 30px;
        }
        .section h3 {
            font-size: 18px;
            color: #1a237e;
            border-bottom: 2px solid #e8eaf6;
            padding-bottom: 8px;
            margin-bottom: 15px;
        }
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }
        .summary-card {
            background: #f5f5f5;
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            border-left: 4px solid #1a237e;
        }
        .summary-card .number {
            font-size: 32px;
            font-weight: 700;
            color: #1a237e;
        }
        .summary-card .label {
            font-size: 13px;
            color: #666;
            margin-top: 5px;
        }
        .breakdown-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 20px;
        }
        .breakdown-section {
            background: #fafafa;
            border-radius: 6px;
            padding: 15px;
        }
        .breakdown-section h4 {
            font-size: 14px;
            color: #333;
            margin-bottom: 10px;
        }
        .breakdown-item {
            display: flex;
            justify-content: space-between;
            padding: 4px 0;
            font-size: 13px;
            border-bottom: 1px solid #eee;
        }
        .breakdown-item:last-child {
            border-bottom: none;
        }
        .breakdown-item .count {
            font-weight: 600;
            color: #1a237e;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }
        thead {
            background: #1a237e;
            color: #fff;
        }
        th {
            padding: 10px 8px;
            text-align: left;
            font-weight: 500;
        }
        td {
            padding: 8px;
            border-bottom: 1px solid #e0e0e0;
            vertical-align: top;
        }
        tr:nth-child(even) {
            background: #f9f9f9;
        }
        tr:hover {
            background: #e8eaf6;
        }
        .result-success {
            color: #2e7d32;
            font-weight: 600;
        }
        .result-failure {
            color: #c62828;
            font-weight: 600;
        }
        .compliance-tag {
            display: inline-block;
            background: #e8eaf6;
            color: #1a237e;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 11px;
            margin: 1px;
        }
        .footer {
            background: #f5f5f5;
            padding: 20px 40px;
            border-top: 2px solid #e0e0e0;
            font-size: 12px;
            color: #666;
            text-align: center;
        }
        .footer p {
            margin-bottom: 5px;
        }
        .no-data {
            text-align: center;
            padding: 40px;
            color: #999;
            font-style: italic;
        }
        @media print {
            body {
                background: #fff;
            }
            .container {
                box-shadow: none;
            }
            .header {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            thead {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="header-text">
                <h1>FDA 21 CFR Part 11 Compliance Audit Report</h1>
                <h2>Electronic Records and Signatures - Audit Trail</h2>
            </div>
            <div class="fda-logo-placeholder">
                FDA<br>Logo
            </div>
        </div>

        <div class="metadata">
            <div class="metadata-item">
                <strong>Report Period:</strong> {{ report_start_date }} to {{ report_end_date }}
            </div>
            <div class="metadata-item">
                <strong>Generated:</strong> {{ ansible_date_time.iso8601 }}
            </div>
            <div class="metadata-item">
                <strong>System:</strong> Elastic Observability + Ansible Automation
            </div>
            <div class="metadata-item">
                <strong>Facility ID:</strong> {{ lookup('env', 'FACILITY_ID') | default('FDA-DEMO-001', true) }}
            </div>
        </div>

        <div class="content">
            <div class="section">
                <h3>Executive Summary</h3>
                <div class="summary-grid">
                    <div class="summary-card">
                        <div class="number">{{ total_events }}</div>
                        <div class="label">Total Audit Events</div>
                    </div>
                    <div class="summary-card">
                        <div class="number">{{ events_by_category | length }}</div>
                        <div class="label">Event Categories</div>
                    </div>
                    <div class="summary-card">
                        <div class="number">{{ events_by_result.get('success', []) | length if events_by_result is mapping else 0 }}</div>
                        <div class="label">Successful Actions</div>
                    </div>
                    <div class="summary-card">
                        <div class="number">{{ events_by_result.get('failure', []) | length if events_by_result is mapping else 0 }}</div>
                        <div class="label">Failed Actions</div>
                    </div>
                </div>
            </div>

            <div class="section">
                <h3>Event Breakdown</h3>
                <div class="breakdown-grid">
                    <div class="breakdown-section">
                        <h4>By Category</h4>
{% if events_by_category is mapping and events_by_category | length > 0 %}
{% for category, events in events_by_category.items() %}
                        <div class="breakdown-item">
                            <span>{{ category }}</span>
                            <span class="count">{{ events | length }}</span>
                        </div>
{% endfor %}
{% else %}
                        <div class="breakdown-item"><span>No data available</span></div>
{% endif %}
                    </div>
                    <div class="breakdown-section">
                        <h4>By Result</h4>
{% if events_by_result is mapping and events_by_result | length > 0 %}
{% for result, events in events_by_result.items() %}
                        <div class="breakdown-item">
                            <span>{{ result }}</span>
                            <span class="count">{{ events | length }}</span>
                        </div>
{% endfor %}
{% else %}
                        <div class="breakdown-item"><span>No data available</span></div>
{% endif %}
                    </div>
                    <div class="breakdown-section">
                        <h4>By Actor</h4>
{% if events_by_actor is mapping and events_by_actor | length > 0 %}
{% for actor, events in events_by_actor.items() %}
                        <div class="breakdown-item">
                            <span>{{ actor }}</span>
                            <span class="count">{{ events | length }}</span>
                        </div>
{% endfor %}
{% else %}
                        <div class="breakdown-item"><span>No data available</span></div>
{% endif %}
                    </div>
                </div>
            </div>

            <div class="section">
                <h3>Detailed Audit Trail</h3>
{% if audit_events | length > 0 %}
                <table>
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Action</th>
                            <th>Actor</th>
                            <th>Target</th>
                            <th>Result</th>
                            <th>Correlation ID</th>
                            <th>Compliance Tags</th>
                        </tr>
                    </thead>
                    <tbody>
{% for event in audit_events %}
                        <tr>
                            <td>{{ event['@timestamp'] | default('N/A') }}</td>
                            <td>{{ event.action | default('N/A') }}</td>
                            <td>{{ event.actor | default('N/A') }}</td>
                            <td>{{ event.target | default('N/A') }}</td>
                            <td class="{{ 'result-success' if event.result | default('') == 'success' else 'result-failure' }}">
                                {{ event.result | default('N/A') }}
                            </td>
                            <td>{{ event.correlation_id | default('N/A') }}</td>
                            <td>
{% if event.compliance_tags is defined and event.compliance_tags is iterable and event.compliance_tags is not string %}
{% for tag in event.compliance_tags %}
                                <span class="compliance-tag">{{ tag }}</span>
{% endfor %}
{% else %}
                                <span class="compliance-tag">{{ event.compliance_tags | default('N/A') }}</span>
{% endif %}
                            </td>
                        </tr>
{% endfor %}
                    </tbody>
                </table>
{% else %}
                <div class="no-data">
                    No audit events found for the specified date range.<br>
                    Verify that the Elasticsearch audit trail index is populated and accessible.
                </div>
{% endif %}
            </div>
        </div>

        <div class="footer">
            <p><strong>This report was generated automatically. All records are maintained in compliance with 21 CFR Part 11.</strong></p>
            <p>Electronic records are protected with audit trails, access controls, and electronic signatures as required.</p>
            <p>Report generated by Elastic Observability + Ansible Automation Platform</p>
        </div>
    </div>
</body>
</html>
